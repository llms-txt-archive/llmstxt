{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "commit_title",
    "commit_body",
    "release_title",
    "release_notes_markdown",
    "key_changes"
  ],
  "properties": {
    "commit_title": {
      "type": "string",
      "minLength": 12,
      "maxLength": 72,
      "pattern": "^sync: [A-Za-z0-9`(][A-Za-z0-9`(),/&' .-]{4,62}[A-Za-z0-9`)]$"
    },
    "commit_body": {
      "type": "string",
      "minLength": 6,
      "pattern": "^- .+(?:\\\\n- .+){1,3}$"
    },
    "release_title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120
    },
    "release_notes_markdown": {
      "type": "string",
      "minLength": 1,
      "pattern": "^## Summary(?:.|\\n)+"
    },
    "key_changes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
